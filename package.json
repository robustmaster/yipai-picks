{
  "name": "yipai-picks",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit && vite build",
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy && npm run db:migrate:remote",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250709.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wrangler": "^4.24.0"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "D1 数据库，用来保存推荐作者列表。部署时 Cloudflare 会自动创建并绑定。"
      },
      "IMAGES": {
        "description": "R2 bucket，用来保存后台上传的头像。部署时 Cloudflare 会自动创建并绑定。"
      },
      "ADMIN_USERNAME": {
        "description": "后台登录账号。可以不填，不填时默认为 admin。"
      },
      "ADMIN_PASSWORD": {
        "description": "后台登录密码。部署后打开 /admin 时使用这个密码登录。建议使用一段随机字符串。"
      }
    }
  }
}
